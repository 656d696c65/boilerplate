# ==============================================================================
# API Production Environment Variables
# ==============================================================================
# Replace these values with actual production credentials

ENV=production
VERBOSE=false
PORT=3000

CORS_ORIGIN=https://app.boilerplate.example.com
COOKIES_DOMAIN=boilerplate.example.com
COOKIES_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_STRING

API_BASE_URL=https://api.boilerplate.example.com
WEBSITE_BASE_URL=https://app.boilerplate.example.com

SQL_DATABASE_URL=postgresql://user:password@db-host:5432/boilerplate
